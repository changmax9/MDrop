    "MDrop works entirely on this Mac. It does not upload files, create an account, or collect analytics.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop works entirely on this Mac. It does not upload files, create an account, or collect analytics."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop 完全在这台 Mac 上运行。它不会上传文件、创建账户或收集分析数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop 完全在這部 Mac 上運作，不會上傳檔案、建立帳號或收集分析資料。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MDropはこのMac上だけで動作します。ファイルのアップロード、アカウント作成、分析情報の収集は行いません。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop fonctionne entièrement sur ce Mac. Il n’envoie aucun fichier, ne crée aucun compte et ne collecte aucune donnée d’analyse."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop работает только на этом Mac. Приложение не загружает файлы, не создаёт учётную запись и не собирает аналитику."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop funciona íntegramente en este Mac. No sube archivos, no crea cuentas ni recopila datos analíticos."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O MDrop funciona inteiramente neste Mac. Não envia ficheiros, não cria contas nem recolhe dados analíticos."
          }
        }
      }
    },
