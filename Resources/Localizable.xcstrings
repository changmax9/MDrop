    "MDrop is provided as-is without warranties. You are responsible for reviewing actions before running them.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop is provided as-is without warranties. You are responsible for reviewing actions before running them."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop 按现状提供，不附带任何保证。运行操作前，你有责任进行确认。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop 依現狀提供，不附帶任何保證。執行操作前，你有責任先行確認。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MDropは現状有姿で提供され、保証はありません。実行前にアクションの内容を確認する責任は利用者にあります。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop est fourni en l’état, sans garantie. Il vous appartient de vérifier les actions avant de les exécuter."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop предоставляется «как есть», без гарантий. Вы обязаны проверять действия перед их запуском."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MDrop se proporciona tal cual, sin garantías. Es tu responsabilidad revisar las acciones antes de ejecutarlas."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O MDrop é fornecido tal como está, sem garantias. É da sua responsabilidade rever as ações antes de as executar."
          }
        }
      }
    },
    "MDrop stores references to original files": {
      "localizations": {
