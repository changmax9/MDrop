    "Floating Shelves use dark Liquid Glass; settings follow the system appearance and accessibility preferences.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Floating Shelves use dark Liquid Glass; settings follow the system appearance and accessibility preferences."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "浮动暂存架使用深色液态玻璃；设置会跟随系统外观和辅助功能偏好。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "浮動暫存架使用深色液態玻璃；設定會跟隨系統外觀與輔助使用偏好。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フローティングシェルフはダークLiquid Glassを使用し、設定はシステムの外観とアクセシビリティに従います。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les étagères flottantes utilisent un Liquid Glass sombre ; les réglages suivent l’apparence et l’accessibilité du système."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плавающие полки используют тёмное Liquid Glass; настройки следуют системному оформлению и универсальному доступу."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los estantes flotantes usan Liquid Glass oscuro; los ajustes siguen la apariencia y accesibilidad del sistema."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As prateleiras flutuantes usam Liquid Glass escuro; as definições seguem a aparência e acessibilidade do sistema."
          }
        }
      }
