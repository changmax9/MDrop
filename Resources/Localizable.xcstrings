    "File actions can move, rename, overwrite, or delete original files. Scripts and automations can make additional changes. Keep backups of important data.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "File actions can move, rename, overwrite, or delete original files. Scripts and automations can make additional changes. Keep backups of important data."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "文件操作可能会移动、重命名、覆盖或删除原始文件。脚本和自动化还可能进行其他更改。请备份重要数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "檔案操作可能會移動、重新命名、覆寫或刪除原始檔案。腳本與自動化也可能進行其他變更。請備份重要資料。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイル操作は元ファイルを移動、名称変更、上書き、削除する場合があります。スクリプトや自動化がさらに変更を加えることもあります。重要なデータはバックアップしてください。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les actions peuvent déplacer, renommer, remplacer ou supprimer les fichiers d’origine. Les scripts et automatisations peuvent effectuer d’autres modifications. Conservez des sauvegardes de vos données importantes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Действия могут перемещать, переименовывать, перезаписывать или удалять исходные файлы. Скрипты и автоматизация могут вносить дополнительные изменения. Храните резервные копии важных данных."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las acciones pueden mover, renombrar, sobrescribir o eliminar archivos originales. Los scripts y automatizaciones pueden realizar cambios adicionales. Conserva copias de seguridad de los datos importantes."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As ações podem mover, mudar o nome, substituir ou eliminar ficheiros originais. Os scripts e automatizações podem fazer alterações adicionais. Mantenha cópias de segurança dos dados importantes."
          }
        }
      }
    },
